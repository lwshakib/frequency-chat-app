# -----------------------------------------------------------------------------
# Database Settings
# -----------------------------------------------------------------------------
# Prisma connection string (PostgreSQL)
DATABASE_URL="postgresql://user:password@localhost:5432/db_name?schema=public"

# -----------------------------------------------------------------------------
# Server Infrastructure
# -----------------------------------------------------------------------------
# Port the Express server will listen on
PORT=4000
# Node environment (development, production)
NODE_ENV=development

# -----------------------------------------------------------------------------
# Authentication (Better Auth)
# -----------------------------------------------------------------------------
# Random secret for session encryption (generate with: openssl rand -base64 32)
BETTER_AUTH_SECRET=YOUR_SECRET_HERE
# Base URL of the auth server (Express)
BETTER_AUTH_URL=http://localhost:4000
# Base URL of the web client (Next.js)
WEB_URL=http://localhost:3000

# Social Auth: Google
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID
GOOGLE_CLIENT_SECRET=YOUR_GOOGLE_CLIENT_SECRET

# -----------------------------------------------------------------------------
# Cloud Storage (Cloudinary)
# -----------------------------------------------------------------------------
CLOUDINARY_API_KEY="YOUR_KEY"
CLOUDINARY_API_SECRET="YOUR_SECRET"
CLOUDINARY_CLOUD_NAME="YOUR_CLOUD_NAME"

# -----------------------------------------------------------------------------
# Redis Configuration (Caching & Socket Synchronization)
# -----------------------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_USERNAME=default
REDIS_PASSWORD=YOUR_PASSWORD

# -----------------------------------------------------------------------------
# Kafka Configuration (Real-time message pipelining)
# -----------------------------------------------------------------------------
KAFKA_BROKER=localhost:9092

# -----------------------------------------------------------------------------
# Email Configuration (Resend)
# -----------------------------------------------------------------------------
RESEND_API_KEY=YOUR_RESEND_KEY